# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: vllm | openai | anthropic
LLM_PROVIDER=vllm
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_TEMPERATURE=0.0

# vLLM settings (used when LLM_PROVIDER=vllm)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_PATH=/workspace/models/Qwen2.5-0.5B-Instruct
VLLM_MAX_MODEL_LEN=2048

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Embedding Provider ───────────────────────────────────────────────────────
# Options: fastembed | openai | huggingface
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── Reranker Provider ────────────────────────────────────────────────────────
# Options: none | flashrank | crossencoder
RERANKER_PROVIDER=none
RERANKER_MODEL=ms-marco-MultiBERT-L-12
RERANKER_TOP_K=5

# ── VectorStore Provider ─────────────────────────────────────────────────────
# Options: qdrant | chroma
VECTORSTORE_PROVIDER=qdrant
COLLECTION_NAME=advanced_rag

# Qdrant (leave QDRANT_URL empty for in-memory mode)
QDRANT_URL=
QDRANT_API_KEY=

# ChromaDB (used when VECTORSTORE_PROVIDER=chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8200
CHROMA_PERSIST_DIR=

# ── RAG ──────────────────────────────────────────────────────────────────────
MAX_RETRIEVAL_DOCS=5
MAX_RETRIES=3
