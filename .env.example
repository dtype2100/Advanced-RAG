# LLM Backend: "vllm" (local) or "openai" (remote)
LLM_BACKEND=vllm

# LLM model name
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_TEMPERATURE=0.0

# vLLM settings (used when LLM_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_PATH=/workspace/models/Qwen2.5-0.5B-Instruct
VLLM_MAX_MODEL_LEN=2048

# OpenAI settings (used when LLM_BACKEND=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Embedding provider
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker provider: "llm" or "none"
RERANKER_BACKEND=llm
# Optional: if empty, uses LLM_MODEL
RERANKER_MODEL=

# Vector DB backend: "qdrant" or "memory"
VECTOR_DB_BACKEND=qdrant
VECTOR_DB_COLLECTION_NAME=advanced_rag

# Legacy alias (still supported for compatibility)
COLLECTION_NAME=advanced_rag

# Qdrant connection (used when VECTOR_DB_BACKEND=qdrant)
# Leave QDRANT_URL empty to use Qdrant in-memory mode.
QDRANT_URL=
QDRANT_API_KEY=

# RAG
MAX_RETRIEVAL_DOCS=5
MAX_RETRIES=3
