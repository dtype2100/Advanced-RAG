# LLM Backend: "vllm" (local) or "openai" (remote)
LLM_BACKEND=vllm

# LLM model name
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_TEMPERATURE=0.0

# vLLM settings (used when LLM_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_PATH=/workspace/models/Qwen2.5-0.5B-Instruct
VLLM_MAX_MODEL_LEN=2048

# OpenAI settings (used when LLM_BACKEND=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Vector DB: "qdrant" (default) or "memory" (in-process, no Qdrant)
VECTOR_BACKEND=qdrant

# Qdrant (leave QDRANT_URL empty for in-process :memory: when VECTOR_BACKEND=qdrant)
QDRANT_URL=
QDRANT_API_KEY=

# Embedding (EMBEDDING_BACKEND=fastembed)
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Optional: set when using a custom model not in the built-in dim map (0 = auto)
EMBEDDING_VECTOR_SIZE=0
COLLECTION_NAME=advanced_rag

# Reranker: "none" or "fastembed" (cross-encoder; downloads model on first use)
RERANKER_BACKEND=none
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=20

# RAG
MAX_RETRIEVAL_DOCS=5
MAX_RETRIES=3
