# =============================================================================
# Advanced RAG – Environment Variable Reference
# Copy this file to .env and fill in the values.
# =============================================================================

# ── LLM Backend ──────────────────────────────────────────────────────────────
# Options: "vllm" (local, default) | "openai" | "anthropic"
LLM_BACKEND=vllm
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_TEMPERATURE=0.0

# ── vLLM settings (LLM_BACKEND=vllm) ─────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_PATH=/workspace/models/Qwen2.5-0.5B-Instruct
VLLM_MAX_MODEL_LEN=2048

# ── OpenAI settings (LLM_BACKEND=openai) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: custom base URL for Azure OpenAI or OpenAI-compatible servers
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# ── Anthropic settings (LLM_BACKEND=anthropic) ───────────────────────────────
# LLM_MODEL=claude-3-5-sonnet-20241022   # set this alongside LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Embedding Provider ────────────────────────────────────────────────────────
# Options: "fastembed" (local, default) | "openai"
EMBEDDING_PROVIDER=fastembed
# FastEmbed model (EMBEDDING_PROVIDER=fastembed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OpenAI embedding model (EMBEDDING_PROVIDER=openai)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Reranker Provider ─────────────────────────────────────────────────────────
# Options: "none" (default) | "cross-encoder" | "cohere"
RERANKER_PROVIDER=none
# cross-encoder model (RERANKER_PROVIDER=cross-encoder)
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Cohere API key and model (RERANKER_PROVIDER=cohere)
# COHERE_API_KEY=your-cohere-api-key
# COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Vector Store Backend ──────────────────────────────────────────────────────
# Options: "qdrant" (default) | "chroma"
VECTORSTORE_BACKEND=qdrant
COLLECTION_NAME=advanced_rag

# Qdrant settings (VECTORSTORE_BACKEND=qdrant)
# Leave QDRANT_URL empty for in-memory mode
QDRANT_URL=
QDRANT_API_KEY=

# Chroma settings (VECTORSTORE_BACKEND=chroma)
# Leave CHROMA_HOST empty for local persistent mode (uses CHROMA_PERSIST_DIR)
# CHROMA_HOST=
# CHROMA_PORT=8002
# CHROMA_PERSIST_DIR=./chroma_db

# ── RAG ───────────────────────────────────────────────────────────────────────
MAX_RETRIEVAL_DOCS=5
MAX_RETRIES=3
